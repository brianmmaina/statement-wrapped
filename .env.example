# Database (postgres). Used by backend and docker-compose.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://statementwrapped:statementwrapped@postgres:5432/statementwrapped

# Redis. Used by backend and docker-compose.
REDIS_URL=redis://redis:6379/0

# Optional: LLM provider API key (Week 2)
# OPENAI_API_KEY=sk-...

# PostgreSQL connection string. Use postgresql+asyncpg:// for async SQLAlchemy.
# Obtain from your database provider or local Postgres install.
DATABASE_URL=postgresql+asyncpg://statementwrapped:statementwrapped@postgres:5432/statementwrapped

# Redis connection URL for health check and analysis caching.
# Default for Docker: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# Optional: Require X-API-Key header on all non-docs requests. Leave unset to disable.
# When set, clients must send header: X-API-Key: <value>
# API_KEY=your-secret-key

# OpenAI API key for LLM transaction categorization. Required when categorization is enabled.
# Obtain from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Comma-separated CORS origins for production (e.g. https://statementwrapped.vercel.app).
# Required when deploying frontend to a different domain than the API.
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
